# PostgreSQL connection
# Generate password: openssl rand -base64 32 | tr -d '/+=' | head -c 32
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=honeypot
DB_USER=honeypot
DB_PASSWORD=CHANGE_ME_GENERATE_A_STRONG_PASSWORD

# Paths (adjust to your install location)
COWRIE_LOG=/home/USER/honeypot/cowrie/var/log/cowrie/cowrie.json
GEOIP_DB=/home/USER/honeypot/parser/GeoLite2-City.mmdb

# API
API_HOST=127.0.0.1
API_PORT=8000

# Dashboard build-time API URL
# Replace with your domain or use a reverse proxy
VITE_API_URL=https://your-honeypot.example.com
